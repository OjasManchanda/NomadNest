<% layout("/layouts/boilerplate") %>

<% 
// Default selectedCategory if not passed
const currentCategory = typeof selectedCategory !== 'undefined' ? selectedCategory : ""; 

const catIcon = (cat) => {
    switch(cat) {
        case "Trending": return "fire";
        case "Iconic Cities": return "city";
        case "Nature": return "tree";
        case "Beaches": return "umbrella-beach";
        case "Mountains": return "mountain";
        case "Swimming Pools": return "person-swimming";
        case "Castles": return "chess-rook";
        case "Camping": return "campground";
        case "Ski Resorts": return "skiing";
        case "Vineyards": return "wine-bottle";
        default: return "circle";
    }
};

const allCategories = ["Trending","Iconic Cities","Nature","Beaches","Mountains","Swimming Pools","Castles","Camping","Ski Resorts","Vineyards"];
%>

<div class="filters-container d-flex flex-wrap align-items-center justify-content-between mb-4">

    <!-- CATEGORY FILTERS -->
    <div class="filters d-flex flex-wrap gap-3">
        <% allCategories.forEach(cat => { %>
            <a href="/listings?category=<%= encodeURIComponent(cat) %>" 
               class="filter <%= currentCategory === cat ? 'active' : '' %>">
                <div><i class="fa-solid fa-<%= catIcon(cat) %>"></i></div>
                <p><%= cat %></p>
            </a>
        <% }) %>
    </div>

    <!-- TAX TOGGLE -->
    <div class="tax-toggle ms-3">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">
                Display total after taxes
            </label>
        </div>
    </div>

</div>

<!-- LISTINGS -->
<div class="row">
    <% if (listings.length === 0) { %>
        <h4 class="text-center text-muted mt-5">No listings found.</h4>
    <% } else { %>
        <% listings.forEach(listing => { %>
            <div class="col-md-4 mb-4 d-flex mt-3 justify-content-center">
                <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                    <div class="card" style="width: 20rem;">
                        <img class="card-img-top" src="<%= listing.image.url %>" alt="listing image">
                        <div class="card-body">
                            <h4 class="card-title"><%= listing.title %></h4>
                            <p class="card-text">
                                &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
                                <span class="tax-info">&nbsp;&nbsp;+18% GST</span>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% }) %>
    <% } %>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    // TAX TOGGLE
    const taxSwitch = document.getElementById("flexSwitchCheckDefault");
    const taxInfo = document.querySelectorAll(".tax-info");
    if (taxSwitch) {
        taxSwitch.addEventListener("change", () => {
            taxInfo.forEach(info => info.classList.toggle("show"));
        });
    }

    // FILTER ACTIVE STATE
    const filters = document.querySelectorAll(".filter");
    filters.forEach(filter => {
        filter.addEventListener("click", function () {
            filters.forEach(f => f.classList.remove("active"));
            this.classList.add("active");
        });
    });
});
</script>
