<% layout("/layouts/boilerplate") %>

  <div class="container mt-4">
    <div class="row">
      <div class="col-lg-7">

        <!-- Listing Title -->
        <h3 class="mb-4">
          <%= listing.title %>
        </h3>

        <div class="card">
          <!-- Listing Image -->
          <img src="<%= listing.image?.url || 'https://via.placeholder.com/800x400' %>" alt="listing image"
            class="card-img-top show-img">

          <div class="card-body">
            <!-- Owner -->
            <p class="text-muted"><i>Owned by <%= listing.owner?.username || "Unknown Host" %></i></p>

            <!-- Description -->
            <p><strong>Description:</strong>
              <%= listing.description %>
            </p>

            <!-- Price -->
            <p><strong>Price:</strong> ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
            </p>

            <!-- Rooms -->
            <p><strong>Rooms:</strong> <span class="badge bg-info text-dark">
                <%= listing.rooms || "N/A" %>
              </span></p>

            <!-- Categories -->
            <p><strong>Categories:</strong>
              <% if (listing.categories && listing.categories.length> 0) { %>
                <% listing.categories.forEach(cat=> { %>
                  <span class="badge bg-secondary me-1 mb-1">
                    <%= cat %>
                  </span>
                  <% }) %>
                    <% } else { %>
                      N/A
                      <% } %>
            </p>

            <!-- Location & Country -->
            <p><strong>Location:</strong>
              <%= listing.location %>
            </p>
            <p><strong>Country:</strong>
              <%= listing.country %>
            </p>

            <!-- Edit and Delete Buttons -->
            <% if (currUser && currUser._id.equals(listing.owner?._id)) { %>
              <div class="d-flex gap-2 mt-3">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">Edit this listing</a>
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                  <button type="submit" class="btn btn-danger">Delete this listing</button>
                </form>
              </div>
              <% } %>
          </div>
        </div>
      </div>

      <!-- Booking Widget Sidebar -->
      <div class="col-lg-5">
        <div class="booking-widget-sticky">
          <div class="card booking-widget shadow-lg">
            <div class="card-body p-3">
              <!-- Price Header -->
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                  <h4 class="mb-0">
                    ₹<%= listing.price.toLocaleString("en-IN") %>
                    <small class="text-muted fs-6">/ night</small>
                  </h4>
                </div>
                <div>
                  <% if (listing.reviews && listing.reviews.length > 0) { %>
                    <% 
                      const totalRating = listing.reviews.reduce((sum, review) => sum + review.rating, 0);
                      const avgRating = (totalRating / listing.reviews.length).toFixed(1);
                    %>
                    <span class="badge bg-success">
                      <i class="fa-solid fa-star"></i> <%= avgRating %> (<%= listing.reviews.length %>)
                    </span>
                  <% } else { %>
                    <span class="badge bg-secondary">
                      <i class="fa-solid fa-star"></i> New
                    </span>
                  <% } %>
                </div>
              </div>

              <hr class="my-2">

              <!-- Booking Form -->
              <% if (currUser) { %>
                <form id="bookingForm" method="POST" action="/listings/<%= listing._id %>/bookings">
                  
                  <!-- Hidden inputs for dates -->
                  <input type="hidden" id="checkInDate" name="checkInDate" required>
                  <input type="hidden" id="checkOutDate" name="checkOutDate" required>
                  
                  <!-- Selected Dates Display -->
                  <div class="selected-dates-display mb-2 p-2 bg-light rounded">
                    <div class="row">
                      <div class="col-6 border-end">
                        <label class="form-label small text-muted mb-0">CHECK-IN</label>
                        <div id="checkInDisplay" class="fw-bold">Select date</div>
                      </div>
                      <div class="col-6 ps-2">
                        <label class="form-label small text-muted mb-0">CHECK-OUT</label>
                        <div id="checkOutDisplay" class="fw-bold">Select date</div>
                      </div>
                    </div>
                    <button type="button" id="clearDates" class="btn btn-sm btn-outline-secondary mt-1 w-100" style="display: none; font-size: 0.75rem;">
                      Clear Dates
                    </button>
                  </div>
                  
                  <!-- Custom Calendar -->
                  <div id="customCalendar" class="custom-calendar mb-2"></div>

                  <!-- Guests Selection -->
                  <div class="mb-2">
                    <label class="form-label small text-muted mb-1">GUESTS</label>
                    <select class="form-select form-select-sm" id="guests" name="guests" required>
                      <% for(let i = 1; i <= (listing.maxGuests || 10); i++) { %>
                        <option value="<%= i %>"><%= i %> <%= i === 1 ? 'guest' : 'guests' %></option>
                      <% } %>
                    </select>
                  </div>

                  <!-- Price Breakdown (Initially Hidden) -->
                  <div id="priceBreakdown" style="display: none;">
                    <hr class="my-2">
                    <div class="price-details">
                      <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">
                          ₹<%= listing.price.toLocaleString("en-IN") %> × <span id="nightsCount">0</span> nights
                        </span>
                        <span id="basePrice">₹0</span>
                      </div>
                      <div class="d-flex justify-content-between mb-2" id="weekendRow" style="display: none;">
                        <span class="text-muted">Weekend surcharge</span>
                        <span id="weekendPrice">₹0</span>
                      </div>
                      <div class="d-flex justify-content-between mb-2" id="seasonalRow" style="display: none;">
                        <span class="text-muted">Seasonal adjustment</span>
                        <span id="seasonalPrice">₹0</span>
                      </div>
                      <div class="d-flex justify-content-between mb-2 text-success" id="discountRow" style="display: none;">
                        <span>Discount (<span id="discountType"></span>)</span>
                        <span id="discountPrice">-₹0</span>
                      </div>
                      <div class="d-flex justify-content-between mb-2" id="insuranceRow" style="display: none;">
                        <span class="text-muted">Travel insurance</span>
                        <span id="insurancePrice">₹0</span>
                      </div>
                      <hr class="my-2">
                      <div class="d-flex justify-content-between">
                        <strong>Total</strong>
                        <strong id="totalPrice">₹0</strong>
                      </div>
                    </div>
                  </div>

                  <!-- Insurance Option -->
                  <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="insuranceAdded" name="insuranceAdded">
                    <label class="form-check-label small" for="insuranceAdded">
                      Add travel insurance (+5%)
                    </label>
                  </div>

                  <!-- Book Button -->
                  <button type="submit" class="btn btn-primary btn-lg w-100 mt-2" id="bookButton">
                    <i class="fa-solid fa-calendar-check me-2"></i>Book Now
                  </button>

                  <p class="text-center text-muted small mt-1 mb-0">You won't be charged yet</p>
                </form>
              <% } else { %>
                <a href="/login" class="btn btn-primary btn-lg w-100">
                  Login to Book
                </a>
              <% } %>

              <!-- Refund Policy Info -->
              <hr class="mt-3 mb-2">
              <div class="refund-policy">
                <h6 class="mb-2">
                  <i class="fa-solid fa-shield-halved me-2 text-primary"></i>
                  Cancellation Policy
                </h6>
                <% 
                  const policy = listing.refundPolicy || 'moderate';
                  let policyText = '';
                  let policyIcon = '';
                  
                  if (policy === 'flexible') {
                    policyText = 'Free cancellation for 24 hours. Cancel before check-in for a full refund.';
                    policyIcon = 'fa-circle-check text-success';
                  } else if (policy === 'moderate') {
                    policyText = 'Cancel 5+ days before check-in for a 50% refund.';
                    policyIcon = 'fa-circle-half-stroke text-warning';
                  } else {
                    policyText = 'Cancel 7+ days before check-in for a 50% refund.';
                    policyIcon = 'fa-circle-xmark text-danger';
                  }
                %>
                <div class="d-flex align-items-start">
                  <i class="fa-solid <%= policyIcon %> me-2 mt-1"></i>
                  <div>
                    <strong class="text-capitalize"><%= policy %></strong>
                    <p class="small text-muted mb-0"><%= policyText %></p>
                  </div>
                </div>
              </div>

              <!-- Property Features -->
              <hr class="my-2">
              <div class="property-features">
                <div class="row g-2">
                  <div class="col-6">
                    <small class="text-muted">
                      <i class="fa-solid fa-users me-1"></i>
                      Max <%= listing.maxGuests || 4 %> guests
                    </small>
                  </div>
                  <div class="col-6">
                    <small class="text-muted">
                      <i class="fa-solid fa-door-open me-1"></i>
                      <%= listing.rooms || 1 %> rooms
                    </small>
                  </div>
                  <% if (listing.instantBooking) { %>
                    <div class="col-12">
                      <small class="text-success">
                        <i class="fa-solid fa-bolt me-1"></i>
                        Instant booking available
                      </small>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <!-- Report Listing -->
          <div class="text-center mt-2">
            <a href="#" class="text-muted small text-decoration-underline">
              <i class="fa-solid fa-flag me-1"></i>Report this listing
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-lg-7">
        <!-- Map Section -->
        <div class="card mt-4">
          <div class="card-body p-0">
            <h5 class="px-4 pt-4 pb-3 mb-0">
              <i class="fa-solid fa-location-dot me-2 text-danger"></i>
              Where you'll be
            </h5>
            <div id="map" style="height: 400px; width: 100%; border-radius: 0 0 12px 12px; background-color: #f7f7f7; position: relative;">
              <div id="map-loading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 1000;">
                <div class="spinner-border text-danger" role="status">
                  <span class="visually-hidden">Loading map...</span>
                </div>
                <p class="mt-2 text-muted">Loading map...</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Review Form -->
        <% if (currUser) { %>
          <div class="row justify-content-center mt-5">
            <div class="col-md-12">
              <h4>Leave a Review</h4>
              <form id="reviewForm" method="POST" action="/listings/<%= listing._id %>/reviews" novalidate>

                
                <fieldset class="starability-slot mb-3">
                  <legend>Rating:</legend>
                  <% for(let i=1; i<=5; i++){ %>
                    <input type="radio" id="rate<%= i %>" name="review[rating]" value="<%= i %>" />
                    <label for="rate<%= i %>" title="<%= i %> star">
                      <%= i %> star
                    </label>
                    <% } %>

                </fieldset>

               
                <div class="mb-3">
                  <label for="comment" class="form-label">Comments (optional)</label>
                  <textarea name="review[comment]" id="comment" rows="4" class="form-control"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Submit</button>
              </form>
            </div>
          </div>
          <% } %>

            <hr>

            <!-- Reviews Section -->
            <div class="reviews-section mt-4">
              <h4 class="mb-3">All Reviews</h4>
              <div class="row g-3">
                <% if (listing.reviews && listing.reviews.length> 0) { %>
                  <% listing.reviews.forEach(review=> { %>
                    <div class="col-md-6">
                      <div class="p-3 border rounded shadow-sm">
                        
                        <h6 class="fw-bold">
                          <i class="fa-solid fa-user me-2"></i>
                          @<%= review.author?.username || "Anonymous" %>
                        </h6>
                        <p>
                          <%= review.comment %>
                        </p>
                        <p>Rating: <span class="badge bg-warning text-dark">
                            <%= review.rating %> ⭐
                          </span></p>

                        <% if(currUser && currUser._id.equals(review.author?._id)) { %>
                          <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            method="POST">
                            <button class="btn btn-danger btn-sm">Delete</button>
                          </form>
                          <% } %>
                      </div>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <p class="text-muted">No reviews yet.</p>
                        <% } %>

              </div>
            </div>

      </div>
    </div>
  </div>

  <!-- Booking Widget Styles -->
  <style>
    .booking-widget-sticky {
      position: sticky;
      top: 100px;
    }

    .booking-widget {
      border: 1px solid #dddddd;
      border-radius: 12px;
      transition: all 0.3s ease;
    }

    .booking-widget:hover {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15) !important;
    }

    .booking-widget .card-body {
      padding: 20px !important;
    }

    .selected-dates-display {
      border: 1px solid #dddddd;
      padding: 10px !important;
      font-size: 0.85rem;
    }

    .selected-dates-display .fw-bold {
      font-size: 0.9rem;
    }

    /* Custom Calendar Styles */
    .custom-calendar {
      background: white;
      border-radius: 8px;
      padding: 10px;
      border: 1px solid #ebebeb;
    }

    .calendar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid #ebebeb;
    }

    .calendar-header h6 {
      margin: 0;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .calendar-nav-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 50%;
      transition: background 0.2s;
      font-size: 0.85rem;
    }

    .calendar-nav-btn:hover {
      background: #f7f7f7;
    }

    .calendar-weekdays {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 3px;
      margin-bottom: 8px;
    }

    .calendar-weekday {
      text-align: center;
      font-size: 0.7rem;
      font-weight: 600;
      color: #717171;
      padding: 3px;
    }

    .calendar-days {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 2px;
    }

    .calendar-day {
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.2s;
      position: relative;
      border: 1.5px solid transparent;
      min-height: 32px;
    }

    .calendar-day:not(.disabled):not(.booked):not(.other-month):hover {
      background: #f7f7f7;
      border-color: #222222;
    }

    .calendar-day.other-month {
      color: #d1d1d1;
      cursor: default;
    }

    .calendar-day.disabled {
      color: #d1d1d1;
      cursor: not-allowed;
      text-decoration: line-through;
    }

    .calendar-day.booked {
      background: #f0f0f0;
      color: #b0b0b0;
      cursor: not-allowed;
      position: relative;
    }

    .calendar-day.booked::after {
      content: '';
      position: absolute;
      width: 1px;
      height: 70%;
      background: #b0b0b0;
      transform: rotate(45deg);
    }

    .calendar-day.selected {
      background: #222222;
      color: white;
      font-weight: 600;
    }

    .calendar-day.in-range {
      background: #f7f7f7;
      border-radius: 0;
    }

    .calendar-day.range-start {
      background: #222222;
      color: white;
      border-radius: 50% 0 0 50%;
    }

    .calendar-day.range-end {
      background: #222222;
      color: white;
      border-radius: 0 50% 50% 0;
    }

    .calendar-day.range-start.range-end {
      border-radius: 50%;
    }

    .calendar-day.today {
      border: 1.5px solid #ff385c;
      font-weight: 600;
    }

    .calendar-legend {
      display: flex;
      gap: 12px;
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid #ebebeb;
      font-size: 0.7rem;
      flex-wrap: wrap;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .legend-box {
      width: 16px;
      height: 16px;
      border-radius: 3px;
      border: 1px solid #ddd;
    }

    .legend-box.booked {
      background: #f0f0f0;
    }

    .legend-box.selected {
      background: #222222;
    }

    .price-details {
      font-size: 0.85rem;
    }

    .refund-policy {
      background: #f7f7f7;
      padding: 12px;
      border-radius: 8px;
      font-size: 0.85rem;
    }

    .refund-policy h6 {
      font-size: 0.9rem;
    }

    .property-features {
      font-size: 0.8rem;
    }

    #bookButton {
      background: linear-gradient(135deg, #ff385c 0%, #e31c5f 100%);
      border: none;
      font-weight: 600;
      padding: 12px;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    #bookButton:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 56, 92, 0.4);
    }

    #bookButton:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    @media (max-width: 991px) {
      .booking-widget-sticky {
        position: relative;
        top: 0;
        margin-bottom: 2rem;
      }
    }
  </style>

  <!-- Booking Calculator Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const pricePerNight = <%= listing.price %>;
      const listingId = '<%= listing._id %>';
      
      // Calendar state
      let currentMonth = new Date();
      let selectedCheckIn = null;
      let selectedCheckOut = null;
      let bookedDates = [];
      let selectingCheckOut = false;
      
      // DOM elements
      const checkInInput = document.getElementById('checkInDate');
      const checkOutInput = document.getElementById('checkOutDate');
      const checkInDisplay = document.getElementById('checkInDisplay');
      const checkOutDisplay = document.getElementById('checkOutDisplay');
      const clearDatesBtn = document.getElementById('clearDates');
      const insuranceCheckbox = document.getElementById('insuranceAdded');
      const priceBreakdown = document.getElementById('priceBreakdown');
      const bookButton = document.getElementById('bookButton');
      
      // Fetch booked dates
      fetch(`/listings/${listingId}/calendar`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.bookings) {
            bookedDates = data.bookings.map(booking => ({
              checkIn: new Date(booking.checkInDate),
              checkOut: new Date(booking.checkOutDate)
            }));
            renderCalendar();
          }
        })
        .catch(error => {
          console.error('Error fetching calendar:', error);
          renderCalendar();
        });
      
      // Check if date is booked
      function isDateBooked(date) {
        const checkDate = new Date(date);
        checkDate.setHours(0, 0, 0, 0);
        
        return bookedDates.some(booking => {
          const start = new Date(booking.checkIn);
          const end = new Date(booking.checkOut);
          start.setHours(0, 0, 0, 0);
          end.setHours(0, 0, 0, 0);
          
          return checkDate >= start && checkDate < end;
        });
      }
      
      // Check if date is in the past
      function isPastDate(date) {
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const checkDate = new Date(date);
        checkDate.setHours(0, 0, 0, 0);
        return checkDate < today;
      }
      
      // Render calendar
      function renderCalendar() {
        const calendarDiv = document.getElementById('customCalendar');
        const year = currentMonth.getFullYear();
        const month = currentMonth.getMonth();
        
        // Calendar header
        const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                           'July', 'August', 'September', 'October', 'November', 'December'];
        
        let html = `
          <div class="calendar-header">
            <button type="button" class="calendar-nav-btn" onclick="previousMonth()">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
            <h6>${monthNames[month]} ${year}</h6>
            <button type="button" class="calendar-nav-btn" onclick="nextMonth()">
              <i class="fa-solid fa-chevron-right"></i>
            </button>
          </div>
        `;
        
        // Weekday headers
        html += '<div class="calendar-weekdays">';
        const weekdays = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];
        weekdays.forEach(day => {
          html += `<div class="calendar-weekday">${day}</div>`;
        });
        html += '</div>';
        
        // Days
        html += '<div class="calendar-days">';
        
        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const daysInPrevMonth = new Date(year, month, 0).getDate();
        
        // Previous month days
        for (let i = firstDay - 1; i >= 0; i--) {
          const day = daysInPrevMonth - i;
          html += `<div class="calendar-day other-month">${day}</div>`;
        }
        
        // Current month days
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        for (let day = 1; day <= daysInMonth; day++) {
          const date = new Date(year, month, day);
          date.setHours(0, 0, 0, 0);
          
          let classes = ['calendar-day'];
          let disabled = false;
          
          // Check if today
          if (date.getTime() === today.getTime()) {
            classes.push('today');
          }
          
          // Check if past date
          if (isPastDate(date)) {
            classes.push('disabled');
            disabled = true;
          }
          
          // Check if booked
          if (isDateBooked(date)) {
            classes.push('booked');
            disabled = true;
          }
          
          // Check if selected
          if (selectedCheckIn && date.getTime() === selectedCheckIn.getTime()) {
            classes.push('range-start');
            if (selectedCheckOut && date.getTime() === selectedCheckOut.getTime()) {
              classes.push('range-end');
            }
          } else if (selectedCheckOut && date.getTime() === selectedCheckOut.getTime()) {
            classes.push('range-end');
          } else if (selectedCheckIn && selectedCheckOut && date > selectedCheckIn && date < selectedCheckOut) {
            classes.push('in-range');
          }
          
          const dateStr = date.toISOString().split('T')[0];
          html += `<div class="${classes.join(' ')}" data-date="${dateStr}" ${disabled ? '' : 'onclick="selectDate(this)"'}>${day}</div>`;
        }
        
        // Next month days
        const totalCells = firstDay + daysInMonth;
        const remainingCells = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
        for (let i = 1; i <= remainingCells; i++) {
          html += `<div class="calendar-day other-month">${i}</div>`;
        }
        
        html += '</div>';
        
        // Legend
        html += `
          <div class="calendar-legend">
            <div class="legend-item">
              <div class="legend-box selected"></div>
              <span>Selected</span>
            </div>
            <div class="legend-item">
              <div class="legend-box booked"></div>
              <span>Booked</span>
            </div>
          </div>
        `;
        
        calendarDiv.innerHTML = html;
      }
      
      // Select date function
      window.selectDate = function(element) {
        const dateStr = element.getAttribute('data-date');
        const date = new Date(dateStr);
        
        if (!selectingCheckOut) {
          // Selecting check-in
          selectedCheckIn = date;
          selectedCheckOut = null;
          selectingCheckOut = true;
          
          checkInInput.value = dateStr;
          checkInDisplay.textContent = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          checkOutDisplay.textContent = 'Select date';
          checkOutInput.value = '';
          clearDatesBtn.style.display = 'block';
          
        } else {
          // Selecting check-out
          if (date <= selectedCheckIn) {
            alert('Check-out date must be after check-in date');
            return;
          }
          
          // Check if any date in range is booked
          let currentDate = new Date(selectedCheckIn);
          currentDate.setDate(currentDate.getDate() + 1);
          
          while (currentDate < date) {
            if (isDateBooked(currentDate)) {
              alert('Your selected dates overlap with an existing booking. Please choose different dates.');
              return;
            }
            currentDate.setDate(currentDate.getDate() + 1);
          }
          
          selectedCheckOut = date;
          selectingCheckOut = false;
          
          checkOutInput.value = dateStr;
          checkOutDisplay.textContent = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          
          calculatePricing();
        }
        
        renderCalendar();
      };
      
      // Clear dates
      clearDatesBtn.addEventListener('click', function() {
        selectedCheckIn = null;
        selectedCheckOut = null;
        selectingCheckOut = false;
        checkInInput.value = '';
        checkOutInput.value = '';
        checkInDisplay.textContent = 'Select date';
        checkOutDisplay.textContent = 'Select date';
        clearDatesBtn.style.display = 'none';
        priceBreakdown.style.display = 'none';
        renderCalendar();
      });
      
      // Navigation functions
      window.previousMonth = function() {
        currentMonth.setMonth(currentMonth.getMonth() - 1);
        renderCalendar();
      };
      
      window.nextMonth = function() {
        currentMonth.setMonth(currentMonth.getMonth() + 1);
        renderCalendar();
      };
      
      // High season months
      const HIGH_SEASON_MONTHS = [5, 6, 7, 11];
      
      function calculateNights(checkIn, checkOut) {
        const oneDay = 24 * 60 * 60 * 1000;
        return Math.round(Math.abs((checkOut - checkIn) / oneDay));
      }
      
      function calculateWeekendNights(checkIn, checkOut) {
        let weekendNights = 0;
        const currentDate = new Date(checkIn);
        
        while (currentDate < checkOut) {
          const dayOfWeek = currentDate.getDay();
          if (dayOfWeek === 5 || dayOfWeek === 6) {
            weekendNights++;
          }
          currentDate.setDate(currentDate.getDate() + 1);
        }
        
        return weekendNights;
      }
      
      function isHighSeason(checkIn, checkOut) {
        return HIGH_SEASON_MONTHS.includes(checkIn.getMonth()) || 
               HIGH_SEASON_MONTHS.includes(checkOut.getMonth());
      }
      
      function daysUntilCheckIn(checkIn) {
        const now = new Date();
        const oneDay = 24 * 60 * 60 * 1000;
        return Math.round((checkIn - now) / oneDay);
      }
      
      function calculatePricing() {
        if (!selectedCheckIn || !selectedCheckOut) {
          priceBreakdown.style.display = 'none';
          bookButton.disabled = true;
          return;
        }
        
        const checkIn = selectedCheckIn;
        const checkOut = selectedCheckOut;
        
        // Calculate nights
        const totalNights = calculateNights(checkIn, checkOut);
        const weekendNights = calculateWeekendNights(checkIn, checkOut);
        
        // Base price
        let basePrice = pricePerNight * totalNights;
        
        // Weekend surcharge (20%)
        const weekendSurcharge = pricePerNight * weekendNights * 0.20;
        
        // Seasonal adjustment (15%)
        let seasonalAdjustment = 0;
        if (isHighSeason(checkIn, checkOut)) {
          seasonalAdjustment = basePrice * 0.15;
        }
        
        // Subtotal before discount
        const subtotal = basePrice + weekendSurcharge + seasonalAdjustment;
        
        // Calculate discount
        const daysAdvance = daysUntilCheckIn(checkIn);
        let discountAmount = 0;
        let discountType = '';
        
        if (totalNights >= 28) {
          discountAmount = subtotal * 0.25;
          discountType = 'Long-term stay';
        } else if (daysAdvance >= 30) {
          discountAmount = subtotal * 0.10;
          discountType = 'Early bird';
        } else if (daysAdvance <= 3 && daysAdvance >= 0) {
          discountAmount = subtotal * 0.15;
          discountType = 'Last-minute';
        }
        
        // Calculate total
        let totalPrice = subtotal - discountAmount;
        
        // Insurance (5%)
        let insuranceAmount = 0;
        if (insuranceCheckbox.checked) {
          insuranceAmount = totalPrice * 0.05;
          totalPrice += insuranceAmount;
        }
        
        // Update UI
        priceBreakdown.style.display = 'block';
        bookButton.disabled = false;
        document.getElementById('nightsCount').textContent = totalNights;
        document.getElementById('basePrice').textContent = '₹' + basePrice.toLocaleString('en-IN');
        
        // Weekend surcharge
        if (weekendSurcharge > 0) {
          document.getElementById('weekendRow').style.display = 'flex';
          document.getElementById('weekendPrice').textContent = '+₹' + weekendSurcharge.toLocaleString('en-IN');
        } else {
          document.getElementById('weekendRow').style.display = 'none';
        }
        
        // Seasonal adjustment
        if (seasonalAdjustment > 0) {
          document.getElementById('seasonalRow').style.display = 'flex';
          document.getElementById('seasonalPrice').textContent = '+₹' + seasonalAdjustment.toLocaleString('en-IN');
        } else {
          document.getElementById('seasonalRow').style.display = 'none';
        }
        
        // Discount
        if (discountAmount > 0) {
          document.getElementById('discountRow').style.display = 'flex';
          document.getElementById('discountType').textContent = discountType;
          document.getElementById('discountPrice').textContent = '-₹' + discountAmount.toLocaleString('en-IN');
        } else {
          document.getElementById('discountRow').style.display = 'none';
        }
        
        // Insurance
        if (insuranceAmount > 0) {
          document.getElementById('insuranceRow').style.display = 'flex';
          document.getElementById('insurancePrice').textContent = '+₹' + insuranceAmount.toLocaleString('en-IN');
        } else {
          document.getElementById('insuranceRow').style.display = 'none';
        }
        
        // Total
        document.getElementById('totalPrice').textContent = '₹' + Math.round(totalPrice).toLocaleString('en-IN');
      }
      
      // Insurance checkbox listener
      insuranceCheckbox.addEventListener('change', calculatePricing);
      
      // Initial state
      bookButton.disabled = true;
    });
  </script>

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script>
    // Wait for DOM and Leaflet to be ready
    document.addEventListener('DOMContentLoaded', function() {
      // Check if Leaflet is loaded
      if (typeof L === 'undefined') {
        console.error('Leaflet library not loaded');
        document.getElementById('map-loading').innerHTML = '<p class="text-danger">Failed to load map library</p>';
        return;
      }

      // Initialize Map
      const mapElement = document.getElementById('map');
      const loadingElement = document.getElementById('map-loading');
      
      if (!mapElement) {
        console.error('Map element not found');
        return;
      }

      try {
        const map = L.map('map', {
          center: [20, 0],
          zoom: 2,
          scrollWheelZoom: true
        });

        // Add OpenStreetMap tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          maxZoom: 19
        }).addTo(map);

        // Hide loading spinner once tiles start loading
        map.on('load', function() {
          if (loadingElement) {
            loadingElement.style.display = 'none';
          }
        });

        // Geocode the location
        const location = "<%= listing.location %>, <%= listing.country %>";
        
        // Using Nominatim for geocoding (free OpenStreetMap service)
        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(location)}`)
          .then(response => response.json())
          .then(data => {
            // Hide loading spinner
            if (loadingElement) {
              loadingElement.style.display = 'none';
            }

            if (data && data.length > 0) {
              const lat = parseFloat(data[0].lat);
              const lon = parseFloat(data[0].lon);
              
              // Set map view to the location
              map.setView([lat, lon], 13);
              
              // Add a marker with custom icon
              const customIcon = L.divIcon({
                className: 'custom-marker',
                html: '<div style="background-color: #ff385c; width: 40px; height: 40px; border-radius: 50% 50% 50% 0; transform: rotate(-45deg); border: 3px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-home" style="color: white; transform: rotate(45deg); font-size: 16px;"></i></div>',
                iconSize: [40, 40],
                iconAnchor: [20, 40]
              });
              
              L.marker([lat, lon], { icon: customIcon })
                .addTo(map)
                .bindPopup(`<strong><%= listing.title %></strong><br>${location}`)
                .openPopup();
              
              // Add a circle to show approximate area
              L.circle([lat, lon], {
                color: '#ff385c',
                fillColor: '#ff385c',
                fillOpacity: 0.1,
                radius: 500
              }).addTo(map);
            } else {
              // Default to a general location if geocoding fails
              console.log('Location not found, using default view');
              map.setView([20, 0], 2);
            }
          })
          .catch(error => {
            console.error('Geocoding error:', error);
            if (loadingElement) {
              loadingElement.style.display = 'none';
            }
            map.setView([20, 0], 2);
          });

        // Fix map display issue
        setTimeout(() => {
          map.invalidateSize();
        }, 100);

      } catch (error) {
        console.error('Map initialization error:', error);
        if (loadingElement) {
          loadingElement.innerHTML = '<p class="text-danger">Failed to initialize map</p>';
        }
      }
    });
  </script>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const reviewForm = document.getElementById("reviewForm");
      const ratingInputs = document.querySelectorAll('input[name="review[rating]"]');
      const ratingError = document.getElementById("ratingError");

      reviewForm.addEventListener("submit", (e) => {
        const selectedRating = Array.from(ratingInputs).some(input => input.checked);
        if (!selectedRating) {
          e.preventDefault(); // Stop form submission
          ratingError.style.display = "block";
        } else {
          ratingError.style.display = "none";
        }
      });
    });
  </script>